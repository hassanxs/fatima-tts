<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Core surfaces ── -->
    <Color x:Key="BgAppColor">#0D0D1C</Color>
    <Color x:Key="BgSidebarColor">#11111E</Color>
    <Color x:Key="BgContentColor">#141424</Color>
    <Color x:Key="BgCardColor">#1E1E32</Color>
    <Color x:Key="BgInputColor">#141422</Color>
    <Color x:Key="BgHoverColor">#252540</Color>
    <Color x:Key="BgSelectedColor">#2E2E50</Color>

    <!-- ── Text ── -->
    <Color x:Key="TextPrimaryColor">#EEEEFF</Color>
    <Color x:Key="TextSecondaryColor">#9898C0</Color>
    <Color x:Key="TextMutedColor">#606080</Color>
    <Color x:Key="TextAccentColor">#9488F5</Color>

    <!-- ── Borders — brighter so cards are clearly separated ── -->
    <Color x:Key="BorderSubtleColor">#30305A</Color>
    <Color x:Key="BorderDefaultColor">#50507A</Color>
    <Color x:Key="BorderFocusColor">#7C6FED</Color>

    <!-- ── Accent (Inworld purple-blue) ── -->
    <Color x:Key="AccentColor">#6C5FE6</Color>
    <Color x:Key="AccentHoverColor">#7D71F0</Color>
    <Color x:Key="AccentPressedColor">#5A4FCC</Color>
    <Color x:Key="AccentForeColor">#FFFFFF</Color>

    <!-- ── Status ── -->
    <Color x:Key="SuccessColor">#1D9E75</Color>
    <Color x:Key="WarningColor">#EF9F27</Color>
    <Color x:Key="DangerColor">#E24B4A</Color>
    <Color x:Key="InfoColor">#378ADD</Color>

    <!-- ── Accent badge (pill for "Instant Clone", "1 cloned" etc.) ── -->
    <Color x:Key="BadgeBgColor">#2A1F6B</Color>
    <Color x:Key="BadgeFgColor">#A99EF5</Color>
    <SolidColorBrush x:Key="BadgeBgBrush" Color="{StaticResource BadgeBgColor}"/>
    <SolidColorBrush x:Key="BadgeFgBrush" Color="{StaticResource BadgeFgColor}"/>

    <!-- ── Brushes ── -->
    <SolidColorBrush x:Key="BgAppBrush"       Color="{StaticResource BgAppColor}"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="{StaticResource BgSidebarColor}"/>
    <SolidColorBrush x:Key="BgContentBrush"   Color="{StaticResource BgContentColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgInputBrush"     Color="{StaticResource BgInputColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush"     Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgSelectedBrush"  Color="{StaticResource BgSelectedColor}"/>
    <!-- Dropdown popup always uses a solid opaque dark surface -->
    <SolidColorBrush x:Key="BgDropdownBrush"  Color="#1C1C30"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextAccentBrush"    Color="{StaticResource TextAccentColor}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush"  Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush"   Color="{StaticResource BorderFocusColor}"/>

    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentForeBrush"    Color="{StaticResource AccentForeColor}"/>

    <SolidColorBrush x:Key="SuccessBrush"  Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"  Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="InfoBrush"     Color="{StaticResource InfoColor}"/>

    <!-- ── Sidebar nav item active gradient ── -->
    <LinearGradientBrush x:Key="NavItemActiveBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2A2448" Offset="0"/>
        <GradientStop Color="#1C1C30" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── CTA button gradient ── -->
    <LinearGradientBrush x:Key="CtaButtonBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6C5FE6" Offset="0"/>
        <GradientStop Color="#5B8EE6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CtaButtonHoverBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7D71F0" Offset="0"/>
        <GradientStop Color="#6B9EF0" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
