<Page x:Class="FatimaTTS.Views.BatchDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgContentBrush}"
                Padding="28,20,28,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <!-- Back link -->
                    <Button x:Name="BackButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Height="28" Padding="10,0"
                            Margin="0,0,0,8"
                            Click="BackButton_Click">
                        <TextBlock Text="← Batch Generate" FontSize="11"/>
                    </Button>
                    <TextBlock x:Name="BatchTitleText"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="BatchSubtitleText"
                               Style="{StaticResource TextSecondary}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="OpenFolderButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="34" Padding="14,0" Margin="0,0,8,0"
                            Click="OpenFolder_Click">
                        <TextBlock Text="📁  Open Folder" FontSize="12"/>
                    </Button>
                    <Button x:Name="MergeButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="34" Padding="14,0" Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="Merge_Click">
                        <TextBlock Text="⊕  Merge with FFmpeg" FontSize="12"/>
                    </Button>
                    <Button x:Name="DeleteBatchButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="34" Padding="14,0"
                            Click="DeleteBatch_Click">
                        <TextBlock Text="🗑  Delete Batch" FontSize="12"
                                   Foreground="{DynamicResource DangerBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats bar -->
        <Border DockPanel.Dock="Top"
                Padding="28,12"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource CardStyle}" Padding="14,8" MinWidth="90" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="StatTotal" Text="0" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Total Jobs" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="14,8" MinWidth="90" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="StatCompleted" Text="0" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="Completed" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="14,8" MinWidth="90" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="StatFailed" Text="0" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"/>
                        <TextBlock Text="Failed" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Padding="14,8" MinWidth="110">
                    <StackPanel>
                        <TextBlock x:Name="StatChars" Text="0" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="Chars Billed" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Player bar -->
        <Border x:Name="PlayerBar"
                DockPanel.Dock="Bottom"
                Visibility="Collapsed"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12,20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock x:Name="PlayerTitle" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                    <Border Height="4" Background="{DynamicResource BorderSubtleBrush}"
                            CornerRadius="2" VerticalAlignment="Center"
                            Cursor="Hand" MouseLeftButtonDown="PlayerTrack_Click">
                        <Grid>
                            <Border x:Name="PlayerFill" Background="{DynamicResource AccentBrush}"
                                    CornerRadius="2" HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                    </Border>
                    <Grid Margin="0,4,0,0">
                        <TextBlock x:Name="PlayerPos" Text="0:00" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="PlayerDur" Text="0:00" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Button Style="{StaticResource IconButtonStyle}" Width="34" Height="34"
                            Click="PlayerBack_Click"><TextBlock Text="⏪" FontSize="13"/></Button>
                    <Button x:Name="PlayerPlayBtn" Width="48" Height="38" Margin="8,0"
                            Background="{DynamicResource AccentBrush}" BorderThickness="0"
                            Cursor="Hand" FocusVisualStyle="{x:Null}" Click="PlayerPlayPause_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="18" Height="18">
                            <StackPanel x:Name="PauseIcon" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="5" Height="16" CornerRadius="2" Background="White"/>
                                <Border Width="5" Height="16" CornerRadius="2" Background="White" Margin="4,0,0,0"/>
                            </StackPanel>
                            <Path x:Name="PlayIcon" Visibility="Collapsed" Fill="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Margin="2,0,0,0" Data="M0,0 L14,8 L0,16 Z"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Width="34" Height="34"
                            Click="PlayerFwd_Click"><TextBlock Text="⏩" FontSize="13"/></Button>
                    <Button Style="{StaticResource IconButtonStyle}" Width="34" Height="34" Margin="8,0,0,0"
                            Click="PlayerStop_Click">
                        <Border Width="12" Height="12" CornerRadius="2" Background="{DynamicResource DangerBrush}"/>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PlayerSaveBtn"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="34" Padding="14,0" Click="PlayerSave_Click">
                        <TextBlock Text="↓  Save" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Job list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="JobList" Margin="28,16,28,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Index number -->
                                <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15"
                                        Background="{DynamicResource BgInputBrush}"
                                        Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Index}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                Background="{Binding StatusBg}">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="{Binding StatusFg}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="400"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding VoiceName}"
                                                   Style="{StaticResource TextMuted}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding CharCount}"
                                                   Style="{StaticResource TextMuted}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding FileSize}"
                                                   Style="{StaticResource TextMuted}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding CreatedAt}"
                                                   Style="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               FontSize="11" Foreground="{DynamicResource DangerBrush}"
                                               Margin="0,4,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding HasError}"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="▶  Play"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            FontSize="11" Height="30" Padding="10,0" Margin="0,0,6,0"
                                            Tag="{Binding JobId}" Visibility="{Binding CanPlay}"
                                            Click="PlayJob_Click"/>
                                    <Button Content="↓  Save"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            FontSize="11" Height="30" Padding="10,0" Margin="0,0,6,0"
                                            Tag="{Binding JobId}" Visibility="{Binding CanPlay}"
                                            Click="SaveJob_Click"/>
                                    <Button Content="↻  Resume"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            FontSize="11" Height="30" Padding="10,0" Margin="0,0,6,0"
                                            Tag="{Binding JobId}" Visibility="{Binding CanResume}"
                                            Click="ResumeJob_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Page>
