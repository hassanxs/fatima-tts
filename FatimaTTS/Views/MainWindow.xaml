<Window x:Class="FatimaTTS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fatima TTS"
        Icon="/Assets/icon.ico"
        Height="820" Width="1280"
        MinHeight="680" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgAppBrush}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top"
                        Padding="18,20,18,16"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="F" FontSize="17" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FATIMA TTS" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="VersionText" Text="v1.0.0"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bottom bar: API status + theme toggle -->
                <Border DockPanel.Dock="Bottom"
                        Padding="14,12"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse x:Name="ApiStatusDot" Width="7" Height="7"
                                     Fill="{DynamicResource DangerBrush}"
                                     VerticalAlignment="Center" Margin="4,0,8,0"/>
                            <TextBlock x:Name="ApiStatusText" Text="No API key"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="☀" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="4,0,6,0"/>
                            <ToggleButton x:Name="ThemeToggle"
                                          Width="40" Height="22"
                                          Checked="ThemeToggle_Checked"
                                          Unchecked="ThemeToggle_Unchecked"
                                          ToolTip="Toggle Light / Dark theme">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Track" Width="40" Height="22"
                                                CornerRadius="11"
                                                Background="{DynamicResource BorderDefaultBrush}">
                                            <Border x:Name="Thumb" Width="16" Height="16"
                                                    CornerRadius="8" Background="White"
                                                    HorizontalAlignment="Left"
                                                    Margin="3,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Track" Property="Background"
                                                        Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="Thumb" Property="Margin"
                                                        Value="21,0,0,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Text="🌙" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,10,0,0">

                        <!-- MAIN -->
                        <TextBlock Text="MAIN"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="18,6,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentDashboard" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavDashboard" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavDashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Dashboard grid icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Canvas Width="16" Height="16">
                                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="6" Height="6" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                            <Rectangle Canvas.Left="8" Canvas.Top="0" Width="8" Height="6" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                            <Rectangle Canvas.Left="0" Canvas.Top="8" Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                            <Rectangle Canvas.Left="10" Canvas.Top="8" Width="6" Height="8" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentSettings" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavSettings" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Gear icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}"
                                              Data="M13.5 8c0-.46-.06-.9-.14-1.33l1.47-1.15-1.5-2.6-1.83.69A5.93 5.93 0 0 0 10 2.86V1H6v1.86c-.39.18-.76.4-1.1.65L3.07 2.92l-1.5 2.6 1.47 1.15A6.05 6.05 0 0 0 2.5 8c0 .46.06.9.14 1.33L1.17 10.48l1.5 2.6 1.83-.69c.34.25.71.47 1.1.65V15h4v-1.86c.39-.18.76-.4 1.1-.65l1.83.69 1.5-2.6-1.47-1.15c.08-.43.14-.87.14-1.33zM8 10.5A2.5 2.5 0 1 1 8 5.5a2.5 2.5 0 0 1 0 5z"/>
                                    </Viewbox>
                                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentAbout" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavAbout" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavAbout_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}"
                                              Data="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm1 10.5H7v-5h2v5zm0-6.5H7V3h2v2z"/>
                                    </Viewbox>
                                    <TextBlock Text="About" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- VOICES -->
                        <TextBlock Text="VOICES"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="18,14,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentVoiceLibrary" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavVoiceLibrary" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavVoiceLibrary_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Mic icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}"
                                              Data="M8 1a3 3 0 0 0-3 3v4a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3zm-1 3a1 1 0 0 1 2 0v4a1 1 0 0 1-2 0V4zm6 4a5 5 0 0 1-10 0H1a7 7 0 0 0 6 6.92V16h2v-2.08A7 7 0 0 0 15 8h-2z"/>
                                    </Viewbox>
                                    <TextBlock Text="Voice Library" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentVoiceClone" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavVoiceClone" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavVoiceClone_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Sparkle / wand icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}"
                                              Data="M8 0l1.5 4.5L14 6l-4.5 1.5L8 12 6.5 7.5 2 6l4.5-1.5L8 0zm6 10l.75 2.25L17 13l-2.25.75L14 16l-.75-2.25L11 13l2.25-.75L14 10zM2 12l.5 1.5L4 14l-1.5.5L2 16l-.5-1.5L0 14l1.5-.5L2 12z"/>
                                    </Viewbox>
                                    <TextBlock Text="Voice Cloning" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentVoiceDesign" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavVoiceDesign" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavVoiceDesign_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Pencil/design icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}"
                                              Data="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                    </Viewbox>
                                    <TextBlock Text="Voice Design" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- GENERATE -->
                        <TextBlock Text="GENERATE"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="18,14,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentGenerate" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavGenerate" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavGenerate_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Path Fill="{DynamicResource TextMutedBrush}" Data="M3 2l12 6L3 14z"/>
                                    </Viewbox>
                                    <TextBlock Text="Generate Speech" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentBatch" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavBatch" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavBatch_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Canvas Width="16" Height="16">
                                            <!-- Stacked layers icon — distinct from My Jobs list lines -->
                                            <Polygon Points="8,0 16,4 8,8 0,4" Fill="{DynamicResource TextMutedBrush}"/>
                                            <Polygon Points="0,7 8,11 16,7 16,9 8,13 0,9" Fill="{DynamicResource TextMutedBrush}"/>
                                            <Polygon Points="0,12 8,16 16,12 16,14 8,18 0,14" Fill="{DynamicResource TextMutedBrush}"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Batch Generate" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="3"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border x:Name="AccentMyJobs" Grid.Column="0" Width="3" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                            <Button x:Name="NavMyJobs" Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}" Click="NavMyJobs_Click">
                                <StackPanel Orientation="Horizontal">
                                    <!-- List / jobs icon -->
                                    <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                        <Canvas Width="16" Height="16">
                                            <Rectangle Canvas.Left="0" Canvas.Top="1" Width="16" Height="2" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                            <Rectangle Canvas.Left="0" Canvas.Top="6" Width="12" Height="2" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                            <Rectangle Canvas.Left="0" Canvas.Top="11" Width="14" Height="2" Fill="{DynamicResource TextMutedBrush}" RadiusX="1" RadiusY="1"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="My Jobs" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource BgContentBrush}"/>

    </Grid>
</Window>
