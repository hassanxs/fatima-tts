<Page x:Class="FatimaTTS.Views.VoiceLibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Voice Library"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VoiceCountText"
                               Text="Loading voices…"
                               Style="{StaticResource TextMuted}"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource InputStyle}"
                             Width="220" Height="34"

                             Tag="Search voices…"
                             TextChanged="SearchBox_TextChanged"/>
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="RefreshButton_Click"
                            Margin="8,0,0,0" Height="34" Padding="14,0">
                        <TextBlock Text="↻  Refresh" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter strip -->
        <Border DockPanel.Dock="Top"
                Padding="24,10"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource BgSidebarBrush}">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="FilterAll" Content="All voices"
                             GroupName="VoiceFilter" IsChecked="True"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12" Margin="0,0,16,0"
                             Checked="FilterAll_Checked"/>
                <RadioButton x:Name="FilterSystem" Content="System"
                             GroupName="VoiceFilter"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12" Margin="0,0,16,0"
                             Checked="FilterSystem_Checked"/>
                <RadioButton x:Name="FilterCloned" Content="Cloned"
                             GroupName="VoiceFilter"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             Checked="FilterCloned_Checked"/>
            </StackPanel>
        </Border>

        <!-- Loading / error state -->
        <Border x:Name="LoadingPanel" DockPanel.Dock="Top"
                Padding="24,40" Visibility="Visible">
            <TextBlock x:Name="LoadingText" Text="Loading voices from Inworld…"
                       Style="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Voice grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,24">

                <!-- System voices section -->
                <TextBlock x:Name="SystemSectionHeader"
                           Text="System Voices"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,10"
                           Visibility="Collapsed"/>
                <ItemsControl x:Name="SystemVoicesList"
                              Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260" Margin="0,0,12,12"
                                    Style="{StaticResource CardStyle}"
                                    Padding="14">
                                <StackPanel>
                                    <!-- Voice name + badge row -->
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                CornerRadius="4" Padding="5,2"
                                                Background="{DynamicResource BadgeBgBrush}">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BadgeFgBrush}"/>
                                        </Border>
                                    </Grid>
                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap"
                                               MaxHeight="38"
                                               Margin="0,0,0,6"
                                               Visibility="{Binding HasDescription}"/>
                                    <!-- Language -->
                                    <TextBlock Text="{Binding LanguageDisplay}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Margin="0,0,0,10"/>
                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="▶  Preview"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="11" Height="28" Padding="10,0"
                                                Tag="{Binding VoiceId}"
                                                Click="PreviewVoice_Click"/>
                                        <Button Content="Use Voice"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="11" Height="28" Padding="10,0"
                                                Margin="6,0,0,0"
                                                Tag="{Binding VoiceId}"
                                                Click="UseVoice_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Cloned voices section -->
                <TextBlock x:Name="ClonedSectionHeader"
                           Text="Cloned Voices"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,16,0,10"
                           Visibility="Collapsed"/>
                <ItemsControl x:Name="ClonedVoicesList"
                              Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260" Margin="0,0,12,12"
                                    Style="{StaticResource CardStyle}"
                                    Padding="14"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                CornerRadius="4" Padding="5,2"
                                                Background="{DynamicResource BadgeBgBrush}">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BadgeFgBrush}"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding LanguageDisplay}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="▶  Preview"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="11" Height="28" Padding="10,0"
                                                Tag="{Binding VoiceId}"
                                                Click="PreviewVoice_Click"/>
                                        <Button Content="Use Voice"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="11" Height="28" Padding="10,0"
                                                Margin="6,0,0,0"
                                                Tag="{Binding VoiceId}"
                                                Click="UseVoice_Click"/>
                                        <Button Content="✕"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                FontSize="11" Height="28" Width="28" Padding="0"
                                                Margin="6,0,0,0"
                                                ToolTip="Delete this cloned voice"
                                                Tag="{Binding VoiceId}"
                                                Click="DeleteVoice_Click"
                                                Foreground="{DynamicResource DangerBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Page>
