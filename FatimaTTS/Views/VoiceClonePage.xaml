<Page x:Class="FatimaTTS.Views.VoiceClonePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Voice Cloning"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Create a personalized voice clone from an audio sample"
                           Style="{StaticResource TextMuted}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Margin="24,20,16,24">
                <StackPanel>

                    <!-- Voice name -->
                    <TextBlock Text="VOICE NAME" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="VoiceNameBox"
                             Style="{StaticResource InputStyle}"
                             Height="36"
                             Tag="e.g. My Narrator Voice"
                             Margin="0,0,0,16"/>

                    <!-- Language -->
                    <TextBlock Text="LANGUAGE" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="LanguageComboBox"
                              Style="{StaticResource ComboStyle}"
                              Margin="0,0,0,16"/>

                    <!-- Description (optional) -->
                    <TextBlock Text="DESCRIPTION (OPTIONAL)" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="DescriptionBox"
                             Style="{StaticResource InputStyle}"
                             Height="60" AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Tag="Brief description of this voice's tone and style…"
                             Margin="0,0,0,16"/>

                    <!-- Audio upload -->
                    <TextBlock Text="AUDIO SAMPLE" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,0,0,8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Upload a clear audio sample (WAV or MP3, minimum 10 seconds)"
                                       Style="{StaticResource TextSecondary}"
                                       Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ChooseFileButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ChooseFileButton_Click"
                                        Height="34" Padding="14,0">
                                    <TextBlock Text="📁  Choose File" FontSize="12"/>
                                </Button>
                                <TextBlock x:Name="SelectedFileText"
                                           Text="No file chosen"
                                           Style="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Transcription (optional) -->
                    <TextBlock Text="TRANSCRIPTION (OPTIONAL)"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,8,0,0"/>
                    <TextBox x:Name="TranscriptionBox"
                             Style="{StaticResource InputStyle}"
                             Height="80" AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Tag="Paste the exact transcript of your audio sample for better accuracy…"
                             Margin="0,0,0,16"/>

                    <!-- Remove background noise -->
                    <Border Style="{StaticResource CardStyle}" Padding="14" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Remove Background Noise"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Automatically clean up background noise in your audio sample"
                                           Style="{StaticResource TextMuted}"
                                           Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox x:Name="RemoveNoiseCheckBox"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsChecked="True"/>
                        </Grid>
                    </Border>

                    <!-- Submit -->
                    <Button x:Name="CloneVoiceButton"
                            Style="{StaticResource CtaButtonStyle}"
                            Click="CloneVoiceButton_Click"
                            Height="44"
                            Content="✨  Clone Voice"/>

                    <!-- Status -->
                    <TextBlock x:Name="CloneStatusText"
                               Style="{StaticResource TextSecondary}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Info panel -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BgSidebarBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="TIPS FOR BEST RESULTS"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,8,0,12"/>

                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🎙  Audio Quality"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Use a clean recording with minimal background noise. A quiet room with a good microphone works best."
                                       Style="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="⏱  Duration"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="10–60 seconds is ideal. Longer recordings may improve quality but take more time to process."
                                       Style="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="📝  Transcription"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Providing the exact transcript of your audio significantly improves clone accuracy."
                                       Style="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" FontSize="11"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

    </DockPanel>
</Page>
