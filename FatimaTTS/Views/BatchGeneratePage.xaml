<Page x:Class="FatimaTTS.Views.BatchGeneratePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Batch Generate"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Process multiple jobs at once from manual entry or a CSV/TXT file"
                               Style="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SingleJobButton_Click"
                        Height="34" Padding="14,0">
                    <TextBlock Text="Single Job" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ CENTER: Input ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab switcher — pinned top -->
                <Border Grid.Row="0"
                        Padding="24,12,24,0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TabFile"
                                Style="{StaticResource NavButtonActiveStyle}"
                                Click="TabFile_Click"
                                Height="34" Padding="16,0">
                            <TextBlock Text="📄  Upload File" FontSize="12"/>
                        </Button>
                        <Button x:Name="TabManual"
                                Style="{StaticResource NavButtonStyle}"
                                Click="TabManual_Click"
                                Height="34" Padding="16,0" Margin="4,0,0,0">
                            <TextBlock Text="✏  Manual Entry" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Scrollable content area -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,24">

                <!-- MANUAL ENTRY panel -->
                <StackPanel x:Name="ManualPanel"
                            Margin="24,16,16,0"
                            Visibility="Collapsed">

                    <!-- Job entry card -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="10" Width="20" Height="20"
                                            Margin="0,0,8,0">
                                        <TextBlock x:Name="JobEntryNumber" Text="1"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Job title (optional)"
                                               Style="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBox x:Name="ManualTitleBox"
                                     Style="{StaticResource InputStyle}"
                                     Height="34"
                                     Margin="0,0,0,8"
                                     Tag="e.g. Chapter 1, Intro…"/>

                            <TextBox x:Name="ManualTextBox"
                                     Style="{StaticResource InputStyle}"
                                     MinHeight="140" MaxHeight="260"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Tag="Enter the full text for this job…"
                                     TextChanged="ManualTextBox_TextChanged"/>

                            <Grid Margin="0,8,0,0">
                                <TextBlock x:Name="ManualCharCount"
                                           Text="0 characters"
                                           Style="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource CtaButtonStyle}"
                                        Click="AddToQueueButton_Click"
                                        Height="34" Padding="16,0" FontSize="12"
                                        Content="+ Add to Queue"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- FILE UPLOAD panel -->
                <StackPanel x:Name="FilePanel"
                            Margin="24,16,16,0"
                            Visibility="Visible">

                    <!-- File picker -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Upload File (.txt or .csv)"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ChooseFileButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ChooseFileButton_Click"
                                        Height="34" Padding="14,0">
                                    <TextBlock Text="Choose File" FontSize="12"/>
                                </Button>
                                <TextBlock x:Name="SelectedFileLabel"
                                           Text="No file chosen"
                                           Style="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <Button x:Name="LoadFileButton"
                                    Style="{StaticResource CtaButtonStyle}"
                                    Click="LoadFileButton_Click"
                                    IsEnabled="False"
                                    Height="34" Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Padding="16,0" FontSize="12"
                                    Content="Load into Queue"/>
                        </StackPanel>
                    </Border>

                    <!-- Format guides — side by side -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- TXT format guide -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="TXT File Format"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Separate each job with a line containing only ---"
                                           Style="{StaticResource TextMuted}"
                                           Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <TextBlock FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap">
                                        <Run Foreground="{DynamicResource TextMutedBrush}"># Optional title for Job 1</Run>
                                        <LineBreak/>
                                        <Run>Full text for job one here.</Run>
                                        <LineBreak/>
                                        <Run>Can span multiple lines.</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource AccentBrush}">---</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource TextMutedBrush}"># Optional title for Job 2</Run>
                                        <LineBreak/>
                                        <Run>Full text for job two here.</Run>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- CSV format guide -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="CSV File Format"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Style="{StaticResource TextMuted}" Margin="0,0,0,8">
                                    <Run>One row per job:</Run>
                                    <Run Foreground="{DynamicResource AccentBrush}">Title,Text</Run>
                                </TextBlock>
                                <Border Background="{DynamicResource BgInputBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <TextBlock FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap">
                                        <Run Foreground="{DynamicResource TextMutedBrush}">Title,Text</Run>
                                        <LineBreak/>
                                        <Run>Hook,"Opening hook text goes here."</Run>
                                        <LineBreak/>
                                        <Run>Part 1,"Full text for part one."</Run>
                                        <LineBreak/>
                                        <Run>Outro,"Closing message text."</Run>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Queue -->
                <Border Margin="24,16,16,0"
                        Padding="16"
                        Style="{StaticResource CardStyle}"
                        Visibility="Collapsed"
                        x:Name="QueueCard">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="QUEUE" Style="{StaticResource SectionLabel}"
                                       VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ClearQueueButton_Click"
                                    Height="26" Padding="10,0" FontSize="11">
                                <TextBlock Text="Clear all"/>
                            </Button>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="320"
                                      HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="QueueList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Background="{DynamicResource BgInputBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1" CornerRadius="6">
                                        <StackPanel>
                                            <!-- Normal row -->
                                            <Border Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Index}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding CharCount, StringFormat='{}{0:N0} characters'}"
                                                               Style="{StaticResource TextMuted}"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <!-- Status icon — only visible during/after processing -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusIcon}"
                                                           FontSize="14"
                                                           Foreground="{Binding StatusColor}"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding StatusVisibility}"
                                                           Margin="8,0"/>
                                                <!-- Edit button -->
                                                <Button Grid.Column="3"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Tag="{Binding Index}"
                                                        Click="EditQueueItem_Click"
                                                        ToolTip="Edit"
                                                        Margin="0,0,4,0">
                                                    <TextBlock Text="✎" FontSize="13"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Button>
                                                <!-- Remove button -->
                                                <Button Grid.Column="4"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Tag="{Binding Index}"
                                                        Click="RemoveQueueItem_Click"
                                                        Foreground="{DynamicResource DangerBrush}"
                                                        ToolTip="Remove">
                                                    <TextBlock Text="✕" FontSize="11"/>
                                                </Button>
                                            </Grid>
                                            </Border>

                                            <!-- Inline edit panel (shown when IsEditing=true) -->
                                            <StackPanel Visibility="{Binding EditPanelVisibility}"
                                                        Margin="12,0,12,12">
                                                <Border Height="1"
                                                        Background="{DynamicResource BorderSubtleBrush}"
                                                        Margin="0,0,0,10"/>
                                                <TextBlock Text="Title" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource InputStyle}"
                                                         Height="32"
                                                         Margin="0,0,0,8"/>
                                                <TextBlock Text="Text" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource InputStyle}"
                                                         MinHeight="100" MaxHeight="200"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Margin="0,0,0,10"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Cancel"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Height="30" Padding="12,0" FontSize="11"
                                                            Tag="{Binding Index}"
                                                            Click="CancelEditQueueItem_Click"
                                                            Margin="0,0,8,0"/>
                                                    <Button Content="Save"
                                                            Style="{StaticResource CtaButtonStyle}"
                                                            Height="30" Padding="12,0" FontSize="11"
                                                            Tag="{Binding Index}"
                                                            Click="SaveEditQueueItem_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══ RIGHT: Settings + Start ═══ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BgSidebarBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1,0,0,0">
                <DockPanel>

                    <!-- Bottom action area — Start / Progress+Cancel -->
                    <Border DockPanel.Dock="Bottom"
                            Padding="16,12"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel>

                            <!-- Progress panel (visible while running) -->
                            <StackPanel x:Name="BatchProgressPanel" Visibility="Collapsed" Margin="0,0,0,10">
                                <Grid Margin="0,0,0,6">
                                    <TextBlock x:Name="BatchProgressText"
                                               Text="Starting…"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BatchProgressCounter"
                                               Text="0 / 0"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="BatchProgressBar"
                                             Height="6" Value="0" Maximum="100"
                                             Foreground="{DynamicResource AccentBrush}"
                                             Background="{DynamicResource BorderSubtleBrush}"
                                             BorderThickness="0"
                                             Margin="0,0,0,8"/>
                                <Button x:Name="CancelBatchButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="CancelBatchButton_Click"
                                        Height="32" FontSize="12"
                                        Content="⏹  Cancel Batch"/>
                            </StackPanel>

                            <!-- Start button -->
                            <Button x:Name="StartBatchButton"
                                    Style="{StaticResource CtaButtonStyle}"
                                    Click="StartBatchButton_Click"
                                    IsEnabled="False"
                                    Content="▶  Start Batch Generation"/>

                            <!-- Post-completion: New Batch panel -->
                            <Border x:Name="NewBatchPanel"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource BgInputBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="14,12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="NewBatchSummaryText"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <Button Style="{StaticResource CtaButtonStyle}"
                                            Height="38" Click="NewBatchButton_Click">
                                        <TextBlock Text="+ Start New Batch" FontSize="13" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,16,16,0">

                            <!-- Settings header -->
                            <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="VOICE" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="VoiceComboBox"
                                      Style="{StaticResource ComboStyle}"
                                      Margin="0,0,0,14"/>

                            <TextBlock Text="MODEL" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="ModelComboBox"
                                      Style="{StaticResource ComboStyle}"
                                      Margin="0,0,0,14"/>

                            <TextBlock Text="FORMAT" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="FormatComboBox"
                                      Style="{StaticResource ComboStyle}"
                                      Margin="0,0,0,14"/>

                            <TextBlock Text="SPEAKING RATE" Style="{StaticResource SectionLabel}"/>
                            <ComboBox x:Name="SpeakingRateComboBox"
                                      Style="{StaticResource ComboStyle}"
                                      Margin="0,0,0,14"/>

                            <TextBlock Text="BATCH NAME (OPTIONAL)" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="BatchNameBox"
                                     Style="{StaticResource InputStyle}"
                                     Height="34"
                                     Margin="0,0,0,16"
                                     Tag="e.g. Episode 12 — El Profe"/>

                            <Border Style="{StaticResource PanelDividerStyle}"/>

                            <!-- Usage stats -->
                            <TextBlock Text="THIS BATCH" Style="{StaticResource SectionLabel}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource CardStyle}"
                                        Padding="12,10" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock x:Name="StatJobCount" Text="0"
                                                   FontSize="20" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="Jobs" Style="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                                        Padding="12,10">
                                    <StackPanel>
                                        <TextBlock x:Name="StatTotalChars" Text="0"
                                                   FontSize="20" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="Chars" Style="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource PanelDividerStyle}"/>

                            <!-- Recent batches -->
                            <TextBlock Text="RECENT BATCHES" Style="{StaticResource SectionLabel}"/>
                            <Border x:Name="NoBatchesYet" Padding="0,8">
                                <TextBlock Text="No batches yet"
                                           Style="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <ItemsControl x:Name="RecentBatchList" Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="10,8"
                                                Background="{DynamicResource BgInputBrush}"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Cursor="Hand"
                                                Tag="{Binding Name}"
                                                MouseLeftButtonDown="RecentBatch_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Summary}"
                                                               Style="{StaticResource TextMuted}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="›"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Page>
