<Page x:Class="FatimaTTS.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Dashboard"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,40">

                <!-- Welcome card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Welcome to Fatima TTS"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Generate speech, clone voices, and manage your audio projects — all from one place."
                                   Style="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Stats grid -->
                <TextBlock Text="OVERVIEW" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="TotalJobsStat" Text="0" FontSize="28" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Total Jobs" Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="CompletedStat" Text="0" FontSize="28" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="Completed" Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="CharsBilledStat" Text="0" FontSize="28" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Chars Billed" Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Padding="16,14">
                        <StackPanel>
                            <TextBlock x:Name="SavedStat" Text="0" FontSize="28" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningBrush}"/>
                            <TextBlock Text="Credits Saved*" Style="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock Text="* Credits saved = characters from resumed chunks not re-billed"
                           Style="{StaticResource TextMuted}" Margin="0,4,0,20"/>

                <!-- Quick actions — directly under overview -->
                <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <Button Content="▶  Generate Speech" Style="{StaticResource CtaButtonStyle}"
                            Click="QuickGenerate_Click" Height="40" Width="160" FontSize="13" Margin="0,0,10,0"/>
                    <Button Content="🎙  Voice Library" Style="{StaticResource SecondaryButtonStyle}"
                            Click="QuickVoiceLib_Click" Height="40" Width="150" FontSize="13" Margin="0,0,10,0"/>
                    <Button Content="✨  Clone a Voice" Style="{StaticResource SecondaryButtonStyle}"
                            Click="QuickClone_Click" Height="40" Width="150" FontSize="13"/>
                </StackPanel>

                <!-- Usage chart -->
                <TextBlock Text="CHARACTERS BILLED — LAST 14 DAYS" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock x:Name="ChartTotalText" Text="0 total this period"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Characters billed" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <Border x:Name="ChartEmptyState" Height="160" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="No data yet" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Generate some speech to see usage here"
                                           Style="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Grid x:Name="ChartArea" Visibility="Collapsed" Height="180">
                            <Canvas x:Name="YAxisCanvas" Width="52" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ChartCanvas" Margin="56,0,0,28"
                                    Background="Transparent" ClipToBounds="True"/>
                            <Canvas x:Name="XAxisCanvas" Height="24"
                                    VerticalAlignment="Bottom" Margin="56,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recent jobs -->
                <TextBlock Text="RECENT JOBS" Style="{StaticResource SectionLabel}"/>
                <Border x:Name="RecentJobsEmpty" Style="{StaticResource CardStyle}"
                        Padding="20" Margin="0,0,0,24" Visibility="Visible">
                    <TextBlock Text="No jobs yet — generate your first speech above."
                               Style="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                </Border>
                <ItemsControl x:Name="RecentJobsList" Margin="0,0,0,24" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding MetaLine}" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding CreatedAtShort}"
                                               Style="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
