<Page x:Class="FatimaTTS.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Padding="24,18,24,14"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="About"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,24,24,40" MaxWidth="600" HorizontalAlignment="Left">

                <!-- App identity card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="56" Height="56" CornerRadius="14"
                                    Background="{DynamicResource AccentBrush}">
                                <TextBlock Text="F" FontSize="28" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Fatima TTS"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="VersionLabel"
                                           Text="Version 1.0.0"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="A powerful Windows desktop client for Inworld TTS. Generate high-quality speech from text, clone voices, and manage your audio projects — all from a fast, native app."
                                   Style="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- What's new -->
                <TextBlock Text="WHAT'S NEW IN v1.0.0" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Generate speech from text with live progress tracking"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Batch generation from CSV or TXT files — process entire projects at once"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Voice cloning — create a custom voice from any audio sample"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="In-app audio playback with waveform visualizer and seek control"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="SRT subtitle export with word-level timestamps"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Interrupted jobs resume automatically — never lose completed work"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tech stack -->
                <TextBlock Text="BUILT WITH" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="C# / WPF / .NET 8" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Application framework" Style="{StaticResource TextMuted}" Margin="0,2,0,10"/>
                            <TextBlock Text="NAudio 2.2.1" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Audio playback engine" Style="{StaticResource TextMuted}" Margin="0,2,0,10"/>
                            <TextBlock Text="Windows Credential Manager" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Secure API key storage (DPAPI)" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Inworld TTS API" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Text-to-speech synthesis" Style="{StaticResource TextMuted}" Margin="0,2,0,10"/>
                            <TextBlock Text="CommunityToolkit.Mvvm" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="MVVM helpers" Style="{StaticResource TextMuted}" Margin="0,2,0,10"/>
                            <TextBlock Text="Microsoft.Extensions.DI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Dependency injection" Style="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Links -->
                <TextBlock Text="LINKS" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                    <StackPanel>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Click="CheckUpdates_Click"
                                Height="36" Padding="14,0" Margin="0,0,0,8">
                            <TextBlock Text="↗  Check for Updates" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Click="OpenInworldDocs_Click"
                                Height="36" Padding="14,0" Margin="0,0,0,8">
                            <TextBlock Text="↗  Inworld TTS API Docs" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"
                                Click="OpenDataFolder_Click"
                                Height="36" Padding="14,0">
                            <TextBlock Text="📁  Open App Data Folder" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- System info -->
                <TextBlock Text="SYSTEM" Style="{StaticResource SectionLabel}"/>
                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text=".NET Runtime"
                                       Style="{StaticResource TextMuted}" FontSize="12"/>
                            <TextBlock x:Name="DotNetVersion"
                                       HorizontalAlignment="Right"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="OS Version"
                                       Style="{StaticResource TextMuted}" FontSize="12"/>
                            <TextBlock x:Name="OsVersion"
                                       HorizontalAlignment="Right"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Data folder"
                                       Style="{StaticResource TextMuted}" FontSize="12"/>
                            <TextBlock x:Name="DataFolder"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="280"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
