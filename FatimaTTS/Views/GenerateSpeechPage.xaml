<Page x:Class="FatimaTTS.Views.GenerateSpeechPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgContentBrush}"
      FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Center content -->
            <ColumnDefinition Width="*"/>
            <!-- Right config panel -->
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  CENTER: Text input                                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0">

            <!-- Page header -->
            <Border DockPanel.Dock="Top"
                    Padding="24,18,24,14"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Generate Speech"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="MyJobsButton"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="MyJobsButton_Click"
                            Padding="14,0" Height="34">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="12" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="My Jobs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Text input card -->
            <Border DockPanel.Dock="Top"
                    Margin="24,20,16,0"
                    Style="{StaticResource CardStyle}"
                    Padding="0">
                <DockPanel>
                    <!-- Card header -->
                    <Border DockPanel.Dock="Top"
                            Padding="16,12"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Text to Synthesize"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Char counter -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="CharCountText" Text="0"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" / 100,000"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Job title -->
                    <TextBox x:Name="JobTitleBox"
                             DockPanel.Dock="Top"
                             Style="{StaticResource InputStyle}"
                             Margin="16,14,16,0"
                             Height="36"

                             Tag="Job title (optional)"
                             TextChanged="JobTitleBox_TextChanged"/>

                    <!-- Main text area -->
                    <TextBox x:Name="InputTextBox"
                             DockPanel.Dock="Top"
                             Style="{StaticResource InputStyle}"
                             Margin="16,10,16,0"
                             MinHeight="340"
                             MaxHeight="480"
                             AcceptsReturn="True"
                             AcceptsTab="False"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Tag="Paste or type your text here…"
                             TextChanged="InputTextBox_TextChanged"/>

                    <!-- Hint + chunk preview -->
                    <Border DockPanel.Dock="Top" Padding="16,10,16,14">
                        <Grid>
                            <TextBlock Text="Supports up to 100,000 characters. Long texts are split automatically."
                                       Style="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="ChunkCountText"
                                           Text=""
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Progress / status area (hidden until job runs) -->
            <Border x:Name="ProgressPanel"
                    DockPanel.Dock="Top"
                    Margin="24,12,16,0"
                    Style="{StaticResource CardStyle}"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- Job status header -->
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="JobStatusIcon" Text="↻"
                                       FontSize="14"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="JobStatusText"
                                       Text="Preparing…"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="CancelButton"
                                HorizontalAlignment="Right"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CancelButton_Click"
                                Height="28" Padding="12,0">
                            <TextBlock Text="Cancel" FontSize="11"/>
                        </Button>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar x:Name="JobProgressBar"
                                 Height="4"
                                 Value="0" Maximum="100"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource BorderSubtleBrush}"
                                 BorderThickness="0"
                                 Margin="0,0,0,10"/>

                    <!-- Chunk list -->
                    <ItemsControl x:Name="ChunkList"
                                  MaxHeight="220">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3"
                                        Padding="12,9"
                                        CornerRadius="6"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        Background="{DynamicResource BgInputBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ChunkIndex}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TextPreview}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CharacterCount, StringFormat='{}{0} ch'}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding StatusLabel}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Playback panel (shown after job completes) -->
                    <Border x:Name="PlaybackPanel"
                            Margin="0,14,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>

                            <!-- Waveform canvas -->
                            <Border Background="{DynamicResource BgInputBrush}"
                                    CornerRadius="6" Height="56"
                                    Margin="0,8,0,0"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="WaveformCanvas_Click">
                                <Canvas x:Name="WaveformCanvas"/>
                            </Border>

                            <!-- Progress row -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PositionText" Grid.Column="0"
                                           Text="0:00" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- Seekable progress track -->
                                <Border Grid.Column="1" Height="4"
                                        Background="{DynamicResource BorderSubtleBrush}"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="ProgressTrack_Click">
                                    <Grid>
                                        <Border x:Name="ProgressFill"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Width="0"/>
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="DurationText" Grid.Column="2"
                                           Text="0:00" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Transport controls -->
                            <Grid Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Rewind 10s -->
                                    <Button x:Name="RewindButton"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="34" Height="34"
                                            Click="RewindButton_Click"
                                            ToolTip="Back 10 seconds">
                                        <TextBlock Text="⏪" FontSize="13"/>
                                    </Button>
                                    <!-- Play / Pause -->
                                    <Button x:Name="PlayPauseButton"
                                            Style="{StaticResource CtaButtonStyle}"
                                            Width="48" Height="38"
                                            Margin="10,0"
                                            Click="PlayPauseButton_Click"
                                            FontSize="16">
                                        <TextBlock x:Name="PlayPauseIcon" Text="▶" FontSize="14" Foreground="White"/>
                                    </Button>
                                    <!-- Forward 10s -->
                                    <Button x:Name="ForwardButton"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="34" Height="34"
                                            Click="ForwardButton_Click"
                                            ToolTip="Forward 10 seconds">
                                        <TextBlock Text="⏩" FontSize="13"/>
                                    </Button>
                                </StackPanel>

                                <!-- Export actions -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="ExportSrtButton"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ExportSrtButton_Click"
                                            Height="34" Padding="14,0"
                                            ToolTip="Export subtitle file (.srt) with word timestamps">
                                        <TextBlock Text="↓  Export SRT" FontSize="12"/>
                                    </Button>
                                    <Button x:Name="SaveButton"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SaveButton_Click"
                                            Height="34" Padding="14,0" Margin="8,0,0,0">
                                        <TextBlock Text="↓  Save" FontSize="12"/>
                                    </Button>
                                    <Button x:Name="OpenFolderButton"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenFolderButton_Click"
                                            Margin="8,0,0,0"
                                            Height="34" Padding="14,0">
                                        <TextBlock Text="📁  Folder" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  RIGHT PANEL: Voice, Model, Format, Generate CTA          -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1,0,0,0">
            <DockPanel>

                <!-- CTA pinned to bottom -->
                <Border DockPanel.Dock="Bottom"
                        Padding="16,12"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0">
                    <Button x:Name="GenerateButton"
                            Style="{StaticResource CtaButtonStyle}"
                            Click="GenerateButton_Click"
                            Content="✦  Generate Speech"/>
                </Border>

                <!-- Scrollable config -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,16,16,0">

                        <!-- ── Voice ── -->
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬛" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Voice" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border x:Name="ClonedBadge"
                                        Background="{DynamicResource BadgeBgBrush}"
                                        CornerRadius="4"
                                        Padding="6,3,6,2" Visibility="Collapsed"
                                        Margin="0,0,6,0"
                                        UseLayoutRounding="True">
                                    <TextBlock x:Name="ClonedBadgeText"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BadgeFgBrush}"
                                               LineHeight="10"
                                               UseLayoutRounding="True"/>
                                </Border>
                                <Button x:Name="RefreshVoicesButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="26" Height="26"
                                        ToolTip="Refresh voices"
                                        Click="RefreshVoicesButton_Click">
                                    <TextBlock Text="↻" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Voice selector card -->
                        <Border Style="{StaticResource CardStyle}"
                                Padding="12" Margin="0,0,0,6"
                                Background="{DynamicResource BgCardBrush}">
                            <StackPanel>
                                <ComboBox x:Name="VoiceComboBox"
                                          Style="{StaticResource ComboStyle}"
                                          SelectionChanged="VoiceComboBox_SelectionChanged"
                                          Margin="0,0,0,10"/>

                                <!-- Voice detail -->
                                <StackPanel x:Name="VoiceDetailPanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border x:Name="VoiceTypeBadge"
                                                Background="{DynamicResource BadgeBgBrush}"
                                                CornerRadius="4"
                                                Padding="6,2" Margin="0,0,6,0">
                                            <TextBlock x:Name="VoiceTypeBadgeText"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BadgeFgBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="VoiceDescText"
                                               Style="{StaticResource TextSecondary}"
                                               Margin="0,2,0,6"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="VoiceLangText"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>

                                <!-- Preview button -->
                                <Button x:Name="PreviewVoiceButton"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="PreviewVoiceButton_Click"
                                        Margin="0,8,0,0" Height="32"
                                        HorizontalAlignment="Left"
                                        Padding="14,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▶" FontSize="11" Margin="0,0,6,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Preview Voice" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelDividerStyle}"/>

                        <!-- ── Model ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="⬛" FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Model" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Radio buttons for model selection -->
                        <RadioButton x:Name="ModelRadio1"
                                     Style="{StaticResource ModelRadioStyle}"
                                     GroupName="ModelGroup"
                                     Tag="inworld-tts-1.5-max"
                                     IsChecked="True"
                                     Checked="ModelRadio_Checked">
                            <StackPanel>
                                <TextBlock Text="Inworld TTS 1.5 Max"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Flagship model — best quality + speed balance"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="ModelRadio2"
                                     Style="{StaticResource ModelRadioStyle}"
                                     GroupName="ModelGroup"
                                     Tag="inworld-tts-1.5-mini"
                                     Checked="ModelRadio_Checked">
                            <StackPanel>
                                <TextBlock Text="Inworld TTS 1.5 Mini"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Ultra-fast, most cost-efficient (~120ms latency)"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="ModelRadio3"
                                     Style="{StaticResource ModelRadioStyle}"
                                     GroupName="ModelGroup"
                                     Tag="inworld-tts-1-max"
                                     Checked="ModelRadio_Checked">
                            <StackPanel>
                                <TextBlock Text="Inworld TTS 1.0 Max"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Previous gen — powerful with basic timestamps"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="ModelRadio4"
                                     Style="{StaticResource ModelRadioStyle}"
                                     GroupName="ModelGroup"
                                     Tag="inworld-tts-1"
                                     Checked="ModelRadio_Checked">
                            <StackPanel>
                                <TextBlock Text="Inworld TTS 1.0"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Previous gen — fastest with basic timestamps"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <Border Style="{StaticResource PanelDividerStyle}"/>

                        <!-- ── Output Format ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="⬛" FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Output Format" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox x:Name="FormatComboBox"
                                  Style="{StaticResource ComboStyle}"
                                  Margin="0,0,0,4"/>

                        <Border Style="{StaticResource PanelDividerStyle}"/>

                        <!-- ── Advanced ── -->
                        <Expander x:Name="AdvancedExpander"
                                  Header="Advanced"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,0,0,16">
                            <StackPanel Margin="0,10,0,0">

                                <!-- Temperature -->
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Temperature"
                                               Style="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="TempValueText"
                                               Text="1.1"
                                               Style="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="TemperatureSlider"
                                        Minimum="0.1" Maximum="2.0"
                                        Value="1.1" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True"
                                        Margin="0,0,0,12"
                                        ValueChanged="TemperatureSlider_ValueChanged"/>

                                <!-- Speaking rate -->
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Speaking Rate"
                                               Style="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="RateValueText"
                                               Text="1.0×"
                                               Style="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="SpeakingRateSlider"
                                        Minimum="0.5" Maximum="1.5"
                                        Value="1.0" TickFrequency="0.1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="SpeakingRateSlider_ValueChanged"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

    </Grid>
</Page>
