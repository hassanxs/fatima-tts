<?xml version="1.0" encoding="utf-8"?>
<!--
  Fatima TTS — WiX 4 MSI installer
  Build: wix build FatimaTTS.wxs -o FatimaTTS-installer.msi
  Requires: dotnet tool install -g wix
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="Fatima TTS"
    Version="1.0.0"
    Manufacturer="Hassan Latif / Fatima TTS"
    UpgradeCode="F0C9FC37-F4AA-40D8-9AFF-97D108F34508"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow silent upgrade of older versions -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Fatima TTS is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Install to Program Files -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="FatimaTTS">

        <Component Id="MainExecutable" Guid="4E77ED9A-425D-465F-9516-79A1A51A29CF">
          <File Id="FatimaTTS.exe"
                Source="..\publish\FatimaTTS.exe"
                KeyPath="yes"
                Checksum="yes"/>
        </Component>

        <!-- Start Menu shortcut -->
        <Component Id="StartMenuShortcut" Guid="30B2BC9E-4CA7-405F-AB9E-E1ABDCC49444">
          <Shortcut Id="StartMenuSC"
                    Name="Fatima TTS"
                    Description="Windows-native Inworld TTS client"
                    Target="[INSTALLFOLDER]FatimaTTS.exe"
                    WorkingDirectory="INSTALLFOLDER"/>
          <RemoveFolder Id="RemoveStartMenu" On="uninstall"/>
          <RegistryValue Root="HKCU"
                         Key="Software\FatimaTTS"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes"/>
        </Component>

        <!-- Desktop shortcut (optional — user can decline) -->
        <Component Id="DesktopShortcut" Guid="4EA9D77F-E65F-4A02-919C-F9CC613CA03D">
          <Shortcut Id="DesktopSC"
                    Directory="DesktopFolder"
                    Name="Fatima TTS"
                    Target="[INSTALLFOLDER]FatimaTTS.exe"
                    WorkingDirectory="INSTALLFOLDER"/>
          <RemoveFolder Id="RemoveDesktop" Directory="DesktopFolder" On="uninstall"/>
          <RegistryValue Root="HKCU"
                         Key="Software\FatimaTTS"
                         Name="desktopShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes"/>
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- Add/Remove Programs entry -->
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/hassanxs/fatima-tts"/>
    <Property Id="ARPHELPLINK"     Value="https://github.com/hassanxs/fatima-tts/issues"/>
    <Property Id="ARPNOREPAIR"     Value="1"/>

    <Feature Id="ProductFeature" Title="Fatima TTS" Level="1">
      <ComponentRef Id="MainExecutable"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>

  </Package>
</Wix>
